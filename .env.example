# ─── Shopify Storefront API ───
# Copy this file to .env and fill in your values
# These are injected by Vercel at deploy time

# Your Shopify store domain (e.g. mystore.myshopify.com)
PUBLIC_STORE_DOMAIN=mock.shop

# Storefront API token (public, from Shopify Admin → Apps → Develop apps)
PUBLIC_STOREFRONT_API_TOKEN=

# Storefront API token (private, for server-side use)
PRIVATE_STOREFRONT_API_TOKEN=

# Storefront ID
PUBLIC_STOREFRONT_ID=

# ─── Session ───
# Used to encrypt session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string
